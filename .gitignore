# --- Binary & Executables ---
# The compiled Go application (on Linux, it's usually named after the folder or 'main')
main
server
*.exe
*.exe~
*.dll
*.so
*.dylib

# --- Data & Storage (CRITICAL) ---
# Ignore the actual database file
*.db
*.db-journal

# Ignore the symlink/shortcut to your USB drive
data_link/

# If you create local upload folders for testing, ignore them
uploads/
temp/

# --- Environment & Secrets ---
# Do not upload your server's secret keys or IP configs
.env
config.yaml
auth_tokens.txt

# --- Go Specific ---
# Ignore the dependency folder (Go handles this via go.mod)
vendor/

# --- OS Specific ---
.DS_Store
Thumbs.db